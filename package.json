{
	"name": "react-example",
	"private": true,
	"version": "0.0.0",
	"type": "module",

	"scripts": {
		"dev": "tsx server.ts",
		"build": "vite build",
		"build:server": "tsc server.ts --outDir dist-server --module es2020 --target es2020 --moduleResolution node --esModuleInterop --skipLibCheck",
		"start": "node dist-server/server.js",
		"setup": "npm install --legacy-peer-deps && npm run build && npm run build:server",
		"preview": "vite preview",
		"clean": "rm -rf dist dist-server",
		"lint": "tsc --noEmit"
	},

	"dependencies": {
		"@google/genai": "^1.29.0",
		"@tailwindcss/vite": "^4.1.14",
		"@uiw/react-md-editor": "^4.0.11",
		"@vitejs/plugin-react": "^5.0.4",
		"better-sqlite3": "^12.4.1",
		"clsx": "^2.1.1",
		"date-fns": "^4.1.0",
		"dotenv": "^17.2.3",
		"express": "^4.21.2",
		"express-rate-limit": "^8.3.0",
		"express-session": "^1.19.0",
		"lucide-react": "^0.546.0",
		"motion": "^12.23.24",
		"multer": "^1.4.5-lts.1",
		"otplib": "^13.3.0",
		"qrcode": "^1.5.4",
		"react": "^19.0.0",
		"react-dom": "^19.0.0",
		"react-helmet-async": "^2.0.5",
		"react-markdown": "^10.1.0",
		"react-router-dom": "^6.28.0",
		"tailwind-merge": "^3.5.0",
		"vite": "^6.2.0"
	},

	"devDependencies": {
		"@types/express": "^4.17.21",
		"@types/express-session": "^1.18.2",
		"@types/multer": "^1.4.12",
		"@types/node": "^22.14.0",
		"@types/qrcode": "^1.5.6",
		"autoprefixer": "^10.4.21",
		"tailwindcss": "^4.1.14",
		"tsx": "^4.21.0",
		"typescript": "~5.8.2",
		"vite": "^6.2.0"
	}
}